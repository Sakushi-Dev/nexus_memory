# Copy this file to ".env" and fill in your key.
# Get a key at https://openrouter.ai/keys

OPENROUTER_API_KEY=sk-or-v1-...

# Primary model — the chat response. Any id from https://openrouter.ai/models
# Cheap / good defaults: openai/gpt-4o-mini, google/gemini-2.0-flash-001,
# anthropic/claude-3.5-haiku. Free option: google/gemini-2.0-flash-exp:free
OPENROUTER_MODEL=openai/gpt-4o-mini

# Secondary ("aux") model — runs the Layer V diary (the day-summaries that Nexus
# enqueues). Pick something cheap/fast here. Leave unset to reuse the primary.
OPENROUTER_AUX_MODEL=google/gemini-2.0-flash-001

# Optional — usually leave as-is.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional metadata sent to OpenRouter (shows up in your dashboard).
APP_TITLE=Nexus Chat Demo
APP_URL=http://localhost
