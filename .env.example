# Copy this file to ".env" and fill in your key.
# Get a key at https://openrouter.ai/keys

OPENROUTER_API_KEY=sk-or-v1-...

# Primary model — the chat response. Any id from https://openrouter.ai/models
# Strong picks: google/gemini-3.5-flash (default), google/gemini-3-flash-preview.
# Cheaper: google/gemini-2.5-flash, google/gemini-3.1-flash-lite.
OPENROUTER_MODEL=google/gemini-3.5-flash

# Secondary ("aux") model — runs the Layer V diary (the session summaries that Nexus
# enqueues). Pick something cheap/fast here. Leave unset to reuse the primary.
OPENROUTER_AUX_MODEL=google/gemini-2.5-flash-lite

# Optional — usually leave as-is.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional metadata sent to OpenRouter (shows up in your dashboard).
APP_TITLE=Nexus Chat Demo
APP_URL=http://localhost
